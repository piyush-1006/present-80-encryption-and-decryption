void XORfunc(uint8_t key[10],uint8_t  y){
      if ((y)%2==0)
      {
        key[7]=key[7]^((y)>>1);
      }else{
        key[7]=key[7]^(((y)-1)>>1);
        key[8]=key[8]^128;
      }
      
}
void decryptXORfunc(uint8_t key[10],uint8_t y){
    if ((32-y)%2==0)
      {
        key[7]=key[7]^((32-y)>>1);
      }else{
        key[7]=key[7]^(((32-y)-1)>>1);
        key[8]=key[8]^128;
      }
}
//--------------
void Sfunc(uint8_t key[10]) {
    uint8_t upper = key[0] >> 4;      
    uint8_t lower = key[0] & 0x0F;    

    upper = sbox[upper];              

    key[0] = (upper << 4) | lower;
}

void decryptSfunc(uint8_t key[10]){
    uint8_t upper = key[0] >> 4;      
    uint8_t lower = key[0] & 0x0F;    

    upper = decryptsbox[upper];              

    key[0] = (upper << 4) | lower;
}
