void decryptP_layer(uint8_t layer[8]){
    uint8_t state[8];
    uint8_t temp2[8]={0,0,0,0,0,0,0,0};
    for (int i = 0; i < 8; i++)
    {
        state[i]=layer[i];
    }
    
    for (int j = 0; j < 64; j++)
    {
        uint8_t bit=0;
        uint8_t bit2=0;
        uint8_t y;
        if (j == 63)
           y = 63;
        else
           y = (j * 4) % 63;
                           // uint8_t y=(j*16)%63;  //bit after p-layer
        uint8_t q=y/8;    //byte after p-layer
        uint8_t z=y%8;   //index of bit in that byte
                        
        uint8_t h=j/8;   //byte index before
        uint8_t m=(j%8);  //index in that byte
        // uint8_t n=(1<<m);
        // uint8_t static num=128;//  uint8_t p=pow(2,z); //uses for masking 
        
        bit=(state[h]>>(7-m))&1;
        bit2=bit<<(7-z);
        temp2[q]=temp2[q]|bit2; 
    }
     for (int i = 0; i < 8; i++)
     {
            layer[i]=temp2[i];
     }
}
