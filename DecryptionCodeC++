//*GEN KEY REGISTER*-------------------------------
void rot1(uint8_t key[10]){
    uint8_t msb=(key[0]&0x80)>>7;
    for (int i = 0; i < 9; i++)
    {
        key[i]=key[i]<<1|key[i+1]>>7;
    }
    key[9]=(key[9]<<1)|msb;
}

void decryptrot1(uint8_t key[10]){
    uint8_t lsb=(key[9]&0x01);
    for (int i = 0; i < 9; i++)
    {
        key[9-i]=(key[9-i]>>1)|((key[8-i]&0x01)<<7);
    }
    key[0]=key[0]|(lsb<<7);
}
//--------------
void rotate61(uint8_t key[10]){
    for (int i = 0; i < 61; i++)
    {
        rot1(key);
    }
}
void decryptrotate61(uint8_t key[10]){
    for (int i = 0; i < 61; i++)
    {
        decryptrot1(key);
    }
    
}
