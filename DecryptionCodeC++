void XORAll(uint8_t layer[8],uint8_t roundkey[10]){
    for (int i = 0; i < 8; i++)
    {
        layer[i]=layer[i]^roundkey[i];
    }
    
}
//---------------------
void decryptS_16boxes(uint8_t layer[8]){
     for (int i = 0; i < 8; i++)
     {
        decryptSfunc(layer,i);
     } 
}
