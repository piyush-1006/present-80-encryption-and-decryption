class genKeyregister {
private:
    uint8_t masterkey[10] = {
        0x01,0x23,0x45,0x67,0x89,0xAB,0xCD,0xEF,0x01,0x23
    };

public:
    uint8_t KeyRegister[32][10];

    genKeyregister() {
        uint8_t temp2[10];

        for (int i = 0; i < 10; i++) {
            temp2[i] = masterkey[i];
            KeyRegister[0][i] = masterkey[i];
        }

        for (int i = 0; i < 31; i++) {             
               rotate61(temp2);
               Sfunc(temp2);
               XORfunc(temp2, i + 1);
            
            for (int j = 0; j < 10; j++)
                KeyRegister[i + 1][j] = temp2[j];
        }
    }
};
//---------------------------------P LAYER DECRYPTION

void decryptSfunc(uint8_t layer[8],int i) {
    uint8_t upper = layer[i] >> 4;      
    uint8_t lower = layer[i] & 0x0F;    

    upper = decryptsbox[upper];  
    lower= decryptsbox[lower];            

    layer[i] = (upper << 4) | lower;
} 
